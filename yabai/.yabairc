## EXPERIMENTAL
yabai -m config layout float
create_window_stack="i=0 && x=1470 && y=956 && a=20 && b=33 && c=36 && \
        for ID in \$(yabai -m query --windows --space | jq '.[].id' | tail -r) ; do \
            app_name=\$(yabai -m query --windows --window \$ID | jq -r '.app') && \
            list_of_apps_to_leave_alone=(\"System Settings\" \
                                         \"Raycast\" \
                                         \"Notes\" \
                                         \"QuickTime Player\" \
                                         \"Finder\") && \
            if [[ ! \" \${list_of_apps_to_leave_alone[*]} \" =~ [[:space:]]\${app_name}[[:space:]] ]]; then \
                xpos=\$(( a * \$i )) && \
                if [[ \$i -ne 0 ]] ; then ypos=\$(( c + ( b * \$i ))) ; else ypos=\$(( b * \$i )) ; fi && \
                if [[ \$i -ne 0 ]] ; then ysize=\$(( y - ( b * \$i ) - c )) ; else ysize=\$(( y - ( b * \$i ))) ; fi && \
                yabai -m window \$ID --move abs:0:\$ypos && \
                yabai -m window \$ID --resize abs:1470:\$ysize && \
                (( i++ )) ; \
            fi ; \
        done"


yabai -m signal --add event=window_focused action="$create_window_stack"
yabai -m signal --add event=window_moved action="$create_window_stack"


echo "yabai configuration loaded.."
